# Personal AI Assistant — copy to ~/.config/pai/.env and fill in your values

PAI_MODEL=qwen2.5:7b
PAI_OLLAMA_HOST=http://localhost:11434

MICROSOFT_CLIENT_ID=<your-azure-app-client-id>
MICROSOFT_TENANT_ID=<your-azure-tenant-id>

PAI_NOTES_FOLDER=Personal
PAI_SEARCH_MAX_RESULTS=5

# Optional: override system timezone (defaults to local system timezone)
# PAI_TIMEZONE=America/New_York
